@LIT_SITE_CFG_IN_HEADER@

import sys

config.llvm_tools_dir = "@LLVM_TOOLS_DIR@"
config.python_mlir_obj_root = "@CMAKE_BINARY_DIR@"
# Where the python-cpp project drops python-mlir-opt. CMake doesn't set
# CMAKE_RUNTIME_OUTPUT_DIRECTORY globally for this project, so point at
# the explicit target output directory instead.
config.python_mlir_tools_dir = "@CMAKE_BINARY_DIR@/src/executable/mlir/tools/python-mlir-opt"

import lit.llvm
lit.llvm.initialize(lit_config, config)

lit_config.load_config(config, "@CMAKE_CURRENT_SOURCE_DIR@/lit.cfg.py")
